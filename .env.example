# ---- App ----
APP_NAME="LinClean Open API"
APP_VERSION="0.1.0"
ENVIRONMENT=local
DEBUG=true

# ---- Server ----
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
LOG_JSON=false

# ---- CORS (JSON list) ----
CORS_ORIGINS=["http://localhost:3000"]

# ---- Database (SQLite) ----
# Relative paths are resolved against the project root.
SQLITE_PATH=data/linclean.db
DB_ECHO=false

# ---- Google Safe Browsing ----
# Leave empty to disable GSB lookups in /api/v1/check.
GSB_API_KEY=SECRET_KEY
GSB_CLIENT_ID=linclean
GSB_CLIENT_VERSION=0.1.0
GSB_TIMEOUT_SECONDS=5.0

# ---- URLhaus ----
URLHAUS_RECENT_CSV_URL=https://urlhaus.abuse.ch/downloads/csv_recent/
URLHAUS_ONLINE_CSV_URL=https://urlhaus.abuse.ch/downloads/csv_online/
URLHAUS_REFRESH_INTERVAL_SECONDS=3600
URLHAUS_DOWNLOAD_TIMEOUT_SECONDS=60.0

# ---- Scheduler / URLhaus sync ----
# 스케줄러 켜면 URLHAUS_REFRESH_INTERVAL_SECONDS 주기로 CSV 동기화 실행.
# 부팅 시 1회 동기화는 URLHAUS_SYNC_ON_STARTUP 로 제어. 로컬/CI 에서 비활성화 가능.
SCHEDULER_ENABLED=true
URLHAUS_SYNC_ON_STARTUP=true

# ---- RDAP ----
RDAP_BOOTSTRAP_URL=https://rdap.org/domain/
RDAP_TIMEOUT_SECONDS=5.0
RDAP_CACHE_TTL_SECONDS=86400
RDAP_NEW_DOMAIN_THRESHOLD_DAYS=30

# ---- Scoring ----
SCORE_WEIGHT_GSB=50
SCORE_WEIGHT_URLHAUS=50
SCORE_WEIGHT_RDAP=20
SCORE_MALICIOUS_THRESHOLD=50
